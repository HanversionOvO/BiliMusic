{
  "name": "bilimusic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run copy-preload",
    "preview": "vite preview",
    "copy-preload": "node -e \"const fs=require('fs');fs.cpSync('electron/preload.cjs','dist-electron/preload.cjs');fs.cpSync('electron/icon.png','dist-electron/icon.png')\"",
    "electron:dev": "vite",
    "electron:start": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "framer-motion": "^12.12.0",
    "lucide-react": "^0.511.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "wait-on": "^8.0.0"
  }
}
